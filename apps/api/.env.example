# ─────────────────────────────────────────
# apps/api — Environment variables example
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────

# NestJS
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# PostgreSQL via Supabase
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Direct connection (bypasses pooler — needed for migrations)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase Auth — backend JWT verification only (no supabase-js client here)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Redis (Upstash) — BullMQ queues (Sprint 4+)
REDIS_URL=rediss://:[PASSWORD]@[HOST]:[PORT]

# Cloudflare R2 — avatar / league logo storage (Sprint 2+)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# Resend — transactional email (Sprint 7+)
# RESEND_API_KEY=
# EMAIL_FROM=noreply@tennisillo.app

# Stripe — passive integration (v1.5)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Sentry — error monitoring (Sprint 7+)
# SENTRY_DSN=
